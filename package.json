{
  "name": "lr6-variant15-fitness-ci-cd",
  "version": "1.0.0",
  "description": "ЛР6, вариант 15: CI/CD для unit, API, BDD и UI тестов",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config=jest.config.allure.js",
    "test:unit": "jest --config=jest.config.allure.js",
    "bdd": "cucumber-js",
    "test:api": "cucumber-js",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui && npm run allure:generate",
    "kill": "npx kill-port 3000"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.4.1",
    "allure-jest": "^3.6.0",
    "allure-playwright": "^3.4.1",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0",
    "wait-on": "^8.0.1"
  }
}
